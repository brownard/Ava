    <string name="label_mic_gain_db">Microphone gain (dB)</string>
    <string name="description_mic_gain_db">Software gain applied before wake word detection and streaming (0–24 dB). Increase for far-field pick-up. When set, two detectors run in parallel — boosted audio is only sent to Home Assistant if it is not clipped.</string>

    <string name="label_noise_suppressor">Noise suppressor</string>
    <string name="description_noise_suppressor">Hardware noise suppression. May suppress distant speech — try disabling for far-field use.</string>
    <string name="label_automatic_gain_control">Automatic gain control</string>
    <string name="description_automatic_gain_control">Hardware AGC. Behaviour varies by device and may not boost quiet far-field speech. Try disabling and using the software gain setting instead.</string>
    <string name="label_acoustic_echo_canceler">Acoustic echo canceler</string>
    <string name="description_acoustic_echo_canceler">Hardware echo cancellation. Disable only when the device is not near a speaker playing audio.</string>

    <string name="label_probability_cutoff">Probability cutoff override</string>
    <string name="description_probability_cutoff">Override the wake word model\'s detection threshold (0.10–0.99). Leave blank to use the model default (~0.85). Lower values increase sensitivity but may cause false triggers.</string>
    <string name="label_sliding_window_size">Sliding window size override</string>
    <string name="description_sliding_window_size">Override the number of 10 ms frames required to confirm a detection (2–15). Leave blank to use the model default (~5). Lower values make detection faster.</string>

